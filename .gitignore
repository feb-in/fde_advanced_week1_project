# --- data (DVC-tracked; keep .dvc pointers, not the bytes) ---
data/raw/*
data/interim/*
data/processed/*
data/featurized/*
!data/**/.gitkeep
# keep the small DVC pointer files (they ARE the git record):
!data/**/*.dvc
*.csv
!docs/**/*.csv          # allow small reference CSVs in docs (e.g. feature log)

# --- original Kaggle download (large CSV + data-dictionary PDF; not git-tracked) ---
dataset/

# --- MLflow ---
mlruns/
mlflow.db
*.mlflow

# --- models / artifacts ---
*.pkl
*.joblib
*.onnx
artifacts/
# ...but keep the EDA artifacts: the per-column analysis is expensive to
# reproduce (multi-agent run) and the dashboard needs it on a clean checkout.
!EDA/artifacts/
!EDA/artifacts/*.json

# --- python ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- audit trail: runtime predictions log, contains clinical inputs (PHI-adjacent) ---
# Never commit; production ships these to an access-controlled, append-only sink.
logs/

# --- Evidently drift reports: heavy (~6 MB each) regenerable HTML. Keep the small
#     committed drift_summary.json as the durable record; regenerate HTML on demand. ---
reports/monitoring/*.html

# --- secrets / config ---
.env
kaggle.json
*.key
*.pem
*.p12

# --- local scratch / offline docs (not part of the repo) ---
# reference/ is an offline wget mirror of mlflow.org docs (~11 MB) — local only.
reference/

# --- Great Expectations project scratch (suites/checkpoints are rebuilt in code
#     from src/contracts; data-docs HTML is a regenerated artifact) ---
gx/

# --- os / editor ---
.DS_Store
.idea/
.vscode/

# --- baked model bundle: TRACKED on purpose ---
# The container bakes this in at build time, and CI builds the image WITHOUT any
# MLflow registry access (stateless runner) — so the bundle must be in the repo.
# Regenerate from the @staging alias with: uv run python deploy/export_model.py
# (the negation overrides the global *.pkl rule above for model.pkl).
!deploy/model_bundle/**
deploy/model_bundle/**/__pycache__/

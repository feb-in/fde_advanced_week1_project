# Slim, serving-only image. Multi-stage: build a minimal venv (serving deps only),
# then copy just that venv + app code + baked model into a clean slim final stage.
# Golden invariant: must score 0.074595 for encounter 12522 (load_source=baked-bundle).

# ---------- builder ----------
FROM python:3.12-slim AS builder
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
RUN apt-get update && apt-get install -y --no-install-recommends binutils \
    && rm -rf /var/lib/apt/lists/*
ENV UV_LINK_MODE=copy

RUN uv venv /opt/venv --python 3.12
COPY deploy/requirements-serve.txt /tmp/requirements-serve.txt
RUN uv pip install --python /opt/venv -r /tmp/requirements-serve.txt

# Trim: drop catboost's unused plotting dep (plotly, not imported at inference),
# strip .so debug symbols, drop bytecode caches.
RUN SP=/opt/venv/lib/python3.12/site-packages && \
    rm -rf "$SP"/plotly "$SP"/plotly-* && \
    find "$SP" -name '*.so' -exec strip --strip-unneeded {} + 2>/dev/null || true && \
    find /opt/venv -name '__pycache__' -type d -prune -exec rm -rf {} + 2>/dev/null || true

# ---------- final ----------
FROM python:3.12-slim
ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    MODEL_BUNDLE_DIR=/app/model_bundle
COPY --from=builder /opt/venv /opt/venv

WORKDIR /app
COPY src/app/                ./src/app/
COPY src/features/build_features.py ./src/features/build_features.py
COPY src/data/clean.py       ./src/data/clean.py
COPY src/contracts/          ./src/contracts/
COPY src/models/wrappers.py  ./src/models/wrappers.py
COPY deploy/model_bundle/    ./model_bundle/

# Rootless-safe non-root user (venv is world-readable, no chown needed there).
RUN useradd --uid 1000 --create-home appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000
CMD ["uvicorn", "src.app.app:app", "--host", "0.0.0.0", "--port", "8000"]
